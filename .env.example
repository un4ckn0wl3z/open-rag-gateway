# Core backend
RAG_BACKEND_HOST=0.0.0.0
RAG_BACKEND_PORT=8000
RAG_DATA_PATH=/data/chroma
RAG_COLLECTION=project_rag
# Use 'all-MiniLM-L6-v2' (default/fast) or set another sentence-transformer model name.
RAG_EMBEDDING_MODEL=all-MiniLM-L6-v2
RAG_SOURCE_FILE=/workspace/project/README.md
RAG_SOURCE_DIR=/workspace/project
RAG_SOURCE_MODE=repo
RAG_CHUNK_SIZE=1200
RAG_CHUNK_OVERLAP=200
RAG_MAX_FILE_BYTES=1500000
RAG_EXCLUDE_DIRS=.git,.venv,.rag,node_modules,target,dist,build
RAG_STARTUP_REINDEX=0

# Docker compose bind source (host path)
# Example: RAG_PROJECT_DIR=../.. (from tools/rag_gateway inside a monorepo)
RAG_PROJECT_DIR=../..

# API key format:
# key_id:key_value:scope1,scope2
# scopes: query,sections,cite,admin:index
RAG_API_KEYS=admin:change-me-admin:query,sections,cite,admin:index;client:change-me-client:query,sections,cite;mcp:change-me-mcp:query,sections,cite

# MCP adapter to backend
RAG_BACKEND_URL=http://backend:8000
RAG_MCP_SERVICE_KEY=change-me-mcp
MCP_TRANSPORT=stdio
MCP_HOST=0.0.0.0
MCP_PORT=8001
